{
  "_definitions.yaml": {
    "id": "_definitions",
    "UUID": {
      "term": {
        "$ref": "_terms.yaml#/UUID"
      },
      "type": "string"
    },
    "datetime": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ],
      "term": {
        "$ref": "_terms.yaml#/datetime"
      }
    },
    "to_one": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/UUID"
              }
            }
          },
          "minItems": 1,
          "maxItems": 1
        },
        {
          "$ref": "#/UUID"
        }
      ]
    },
    "to_many": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/UUID"
              }
            }
          },
          "minItems": 1
        },
        {
          "$ref": "#/UUID"
        }
      ]
    }
  },
